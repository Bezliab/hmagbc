<%- include('../partials/head') %> <%- include('../partials/nav') %>
<div class="page active" id="page-contact">
  <div class="page-hero">
    <h1>Get In Touch</h1>
    <p>
      We'd love to hear from you. Reach out and we'll respond within 24 hours.
    </p>
  </div>
  <section>
    <div class="container">
      <div class="contact-grid">
        <div class="contact-form-wrap">
          <h3>Send a Message</h3>
          <div class="form-group">
            <label>Full Name *</label>
            <input placeholder="Your full name" required="" type="text" />
          </div>
          <div class="form-group">
            <label>Email Address *</label>
            <input placeholder="your@email.com" required="" type="email" />
          </div>
          <div class="form-group">
            <label>Phone Number (optional)</label>
            <input placeholder="+234 703 943 2323" type="tel" />
          </div>
          <div class="form-group">
            <label>Subject</label>
            <select>
              <option>General Inquiry</option>
              <option>Prayer Request</option>
              <option>Event Information</option>
              <option>Membership</option>
              <option>Counselling</option>
              <option>Partnership / Giving</option>
              <option>Media Request</option>
            </select>
          </div>
          <div class="form-group">
            <label>Message *</label>
            <textarea
              placeholder="Share your message, prayer request, or inquiry..."
              required=""
              style="height: 370px"
            ></textarea>
          </div>
          <button
            class="btn-primary"
            onclick="submitContact()"
            style="width: 100%; justify-content: center"
          >
            <i
              class="fa fa-paper-plane"
              aria-hidden="true"
              style="width: fit-content"
            ></i>
            Send Message
          </button>
          <div class="form-success" id="contact-success">
            <i class="fa fa-check-circle" aria-hidden="true"></i> Thank you!
            Your message has been sent. We'll respond within 24 hours.
          </div>
        </div>
        <div class="contact-info-wrap">
          <div class="contact-info-card">
            <h3>Find Us</h3>
            <div class="info-row">
              <div class="info-icon">
                <i class="fa fa-map-marker" aria-hidden="true"></i>
              </div>
              <div>
                <div class="info-label">Address</div>
                <div class="info-val" id="contact-address">
                  No 10 Aanuoluwapo Lane 2, Ogunremi, Gbopa<br />Oyo, Nigeria
                </div>
              </div>
            </div>
            <div class="info-row">
              <div class="info-icon">
                <i class="fa fa-phone" aria-hidden="true"></i>
              </div>
              <div>
                <div class="info-label">Phone</div>
                <div class="info-val">
                  +234 703 943 2323<br />+234 701 000 4135
                </div>
              </div>
            </div>
            <div class="info-row">
              <div class="info-icon">
                <i class="fa fa-envelope" aria-hidden="true"></i>
              </div>
              <div>
                <div class="info-label">Email</div>
                <div class="info-val">
                  kingdomofhismercyandglory@gmail.com<br />admin@hismercyandglory.org
                </div>
              </div>
            </div>
            <div class="info-row">
              <div class="info-icon">
                <i class="fa fa-clock-o" aria-hidden="true"></i>
              </div>
              <div>
                <div class="info-label">Service Times</div>
                <div class="info-val">
                  Sunday: 8:00 am<br />Tuesday: 5:00 pm
                </div>
              </div>
            </div>
          </div>
          <div class="map-placeholder">
            <iframe
              id="contact-map-iframe"
              title="His Mercy and Glory Bible Church - Map"
              src="https://www.google.com/maps?q=CRRC%2B8G6&z=17&output=embed"
              width="100%"
              height="100%"
              style="border: 0; border-radius: var(--radius)"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
            <!-- Local SVG fallback (hidden by default) -->
            <img
              id="map-fallback"
              src="/img/map-fallback.svg"
              alt="Map fallback"
              style="
                display: none;
                width: 100%;
                height: 100%;
                border-radius: var(--radius);
                object-fit: cover;
              "
            />
          </div>
          <div
            style="display: flex; gap: 10px; margin-top: 16px; flex-wrap: wrap"
          >
            <button
              class="btn-outline"
              style="flex: 1; justify-content: center"
            >
              Facebook
            </button>
            <button
              class="btn-outline"
              style="flex: 1; justify-content: center"
            >
              YouTube
            </button>
            <button
              class="btn-outline"
              style="flex: 1; justify-content: center"
            >
              Instagram
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
<%- include('../partials/footer') %> <%- include('../partials/scripts') %>
