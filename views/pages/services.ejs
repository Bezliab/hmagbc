<%- include('../partials/head') %> <%- include('../partials/nav') %>
<div class="page active" id="page-services">
  <div class="page-hero">
    <h1>Services &amp; Programmes</h1>
    <p>
      Every gathering is intentional — come ready to encounter God and grow.
    </p>
  </div>
  <!-- Sunday Service -->
  <section>
    <div class="container">
      <div class="section-header">
        <div class="section-label">Weekly Gathering</div>
        <h2 class="section-title">Sunday Service</h2>
      </div>
      <div
        style="
          background: linear-gradient(135deg, var(--green), #1e6b44);
          border-radius: var(--radius-lg);
          padding: 40px;
          color: white;
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 40px;
          align-items: center;
        "
      >
        <div>
          <h3
            style="
              font-family: var(--font-head);
              font-size: 1.8rem;
              margin-bottom: 12px;
            "
          >
            Join Us Every Sunday
          </h3>
          <p style="opacity: 0.85; line-height: 1.8; margin-bottom: 20px">
            One service designed to accommodate everyone. Packed service with a
            devotional atmosphere featuring a full worship experience and
            edification from the word of God with interpretation of mysteries of
            the word.
          </p>
          <div style="display: flex; flex-direction: column; gap: 12px">
            <div
              style="
                background: rgba(255, 255, 255, 0.1);
                padding: 14px 18px;
                border-radius: 10px;
              "
            >
              <strong>Service</strong> — 8:00 AM<br />
              <span style="opacity: 0.7; font-size: 0.85rem"
                >Church Auditorium · Celebration of His Resurrection</span
              >
            </div>
          </div>
        </div>
        <div
          style="
            text-align: center;
            font-size: 8rem;
            opacity: 0.2;
            font-family: var(--font-head);
          "
        >
          <i class="fa fa-church" aria-hidden="true"></i>
        </div>
      </div>
    </div>
  </section>
  <!-- Mid-Week Services -->
  <section class="prog-section">
    <div class="container">
      <div class="section-header">
        <div class="section-label red">Mid-Week</div>
        <h2 class="section-title">Mid-Week Services</h2>
        <p class="section-subtitle">
          Sustaining your spiritual fire through the week with prayer and the
          Word.
        </p>
      </div>
      <div class="prog-grid">
        <div class="prog-card">
          <div class="prog-type">Mid-Week Service 1</div>
          <div class="prog-name">Hour of Revelation</div>
          <div class="prog-schedule">
            <span
              ><i
                class="fa fa-calendar"
                aria-hidden="true"
                style="margin-right: 8px"
              ></i>
              Every Tuesday</span
            >
            <span
              ><i
                class="fa fa-clock"
                aria-hidden="true"
                style="margin-right: 8px"
              ></i>
              5:00 PM – 6:30 PM</span
            >
            <span
              ><i
                class="fa fa-map-marker-alt"
                aria-hidden="true"
                style="margin-right: 8px"
              ></i>
              Church Auditorium</span
            >
          </div>
          <div class="prog-desc">
            An intense, Spirit-filled prayer session dedicated to intercession
            for the church, nation, and individual breakthroughs. Led by the
            prayer department with structured prayer topics each week.
          </div>
        </div>
        <div class="prog-card red">
          <div class="prog-type">Mid-Week Service 2</div>
          <div class="prog-name">Friday Bible Study</div>
          <div class="prog-schedule">
            <span
              ><i
                class="fa fa-calendar"
                aria-hidden="true"
                style="margin-right: 8px"
              ></i>
              Every Friday</span
            >
            <span
              ><i
                class="fa fa-clock"
                aria-hidden="true"
                style="margin-right: 8px"
              ></i>
              7:00 PM – 9:00 PM</span
            >
            <span
              ><i
                class="fa fa-map-marker-alt"
                aria-hidden="true"
                style="margin-right: 8px"
              ></i>
              Main Sanctuary</span
            >
          </div>
          <div class="prog-desc">
            Deep-dive expository Bible teaching by the Senior Pastor or
            designated ministers. Includes group discussions, Q&amp;A sessions,
            and practical application for everyday living. Notes available for
            download.
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- Monthly Programmes -->
  <section>
    <div class="container">
      <div class="section-header">
        <div class="section-label yellow">Monthly</div>
        <h2 class="section-title">Monthly Programmes</h2>
        <p class="section-subtitle">
          Recurring gatherings each month designed for every arm of the church
          family.
        </p>
      </div>
      <div class="prog-grid">
        <div class="prog-card yellow">
          <div class="prog-type">Monthly Programme 1</div>
          <div class="prog-name">All-Night Vigil</div>
          <div class="prog-schedule">
            <span
              ><i
                class="fa fa-calendar"
                aria-hidden="true"
                style="margin-right: 8px"
              ></i>
              Last Friday of Every Month</span
            >
            <span
              ><i
                class="fa fa-clock"
                aria-hidden="true"
                style="margin-right: 8px"
              ></i>
              11:00 PM – 3:00 AM</span
            >
            <span
              ><i
                class="fa fa-map-marker-alt"
                aria-hidden="true"
                style="margin-right: 8px"
              ></i>
              Church Auditorium</span
            >
          </div>
          <div class="prog-desc">
            Monthly night of worship, intercession, and prayer warfare. A
            cherished tradition in the church where members testify of
            significant breakthroughs received at the vigil.
          </div>
        </div>
        <div class="prog-card">
          <div class="prog-type">Monthly Programme 2</div>
          <div class="prog-name">Sabbath for the Troubled</div>
          <div class="prog-schedule">
            <span
              ><i
                class="fa fa-calendar"
                aria-hidden="true"
                style="margin-right: 8px"
              ></i>
              2nd Saturday of Every Month</span
            >
            <span
              ><i
                class="fa fa-clock"
                aria-hidden="true"
                style="margin-right: 8px"
              ></i>
              9:00 AM – 12:00 PM</span
            >
            <span
              ><i
                class="fa fa-map-marker-alt"
                aria-hidden="true"
                style="margin-right: 8px"
              ></i>
              Church Auditorium</span
            >
          </div>
          <div class="prog-desc">
            A monthly edification and empowerment for all who are going through
            various challenges in life. A time of focused prayer, prophetic
            declarations, and practical teachings to uplift the spirit and
            provide hope. Open to all seeking divine intervention and
            encouragement in their struggles.
          </div>
        </div>
        <div class="prog-card red">
          <div class="prog-type">Monthly Programme 3</div>
          <div class="prog-name">Virtuous Women Fellowship</div>
          <div class="prog-schedule">
            <span
              ><i
                class="fa fa-calendar"
                aria-hidden="true"
                style="margin-right: 8px"
              ></i>
              1st Saturday of Month</span
            >
            <span
              ><i
                class="fa fa-clock"
                aria-hidden="true"
                style="margin-right: 8px"
              ></i>
              3:00 PM – 5:30 PM</span
            >
            <span
              ><i
                class="fa fa-map-marker-alt"
                aria-hidden="true"
                style="margin-right: 8px"
              ></i>
              Women's Hall</span
            >
          </div>
          <div class="prog-desc">
            A safe, uplifting space for women of all ages to share, grow in
            faith, learn practical life skills, and support one another. Guest
            speakers, skills workshops, and refreshments monthly.
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- Quarterly Programme -->
  <section style="background: var(--silver)">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Quarterly</div>
        <h2 class="section-title">Quarterly Programme</h2>
      </div>
      <div
        style="
          background: white;
          border-radius: var(--radius-lg);
          padding: 40px;
          border: 1px solid var(--silver-dark);
          box-shadow: var(--shadow-sm);
          max-width: 800px;
          margin: 0 auto;
        "
      >
        <div
          style="
            display: flex;
            gap: 24px;
            align-items: flex-start;
            flex-wrap: wrap;
          "
        >
          <div style="flex: 1; min-width: 260px">
            <div class="prog-type" style="margin-bottom: 8px">
              Quarterly Programme
            </div>
            <h3
              style="
                font-family: var(--font-head);
                font-size: 1.8rem;
                font-weight: 700;
                margin-bottom: 12px;
              "
            >
              Weekend of Transfiguration
            </h3>
            <div class="prog-schedule" style="margin-bottom: 16px">
              <span
                ><i
                  class="fa fa-calendar"
                  aria-hidden="true"
                  style="margin-right: 6px"
                ></i>
                March &amp; June &amp; September &amp; December</span
              >
              <span
                ><i
                  class="fa fa-map-marker-alt"
                  aria-hidden="true"
                  style="margin-right: 6px"
                ></i>
                Church Auditorium</span
              >
            </div>
            <p
              style="
                font-size: 0.9rem;
                color: var(--text-muted);
                line-height: 1.8;
                margin-bottom: 20px;
              "
            >
              The flagship event of the church calendar; three days of
              power-packed ministry, worship concerts, and general assembly.
              Guest ministers of national and international repute are invited.
              Accommodation and feeding packages available for those travelling
              from outside the city.
            </p>
            <button class="btn-primary" onclick="location.href = 'events.html'">
              Register for programme →
            </button>
          </div>
          <div
            style="
              display: grid;
              grid-template-columns: 1fr 1fr;
              gap: 12px;
              flex-shrink: 0;
            "
          >
            <div
              style="
                background: var(--green-pale);
                border-radius: 10px;
                padding: 16px;
                text-align: center;
              "
            >
              <div
                style="
                  font-family: var(--font-head);
                  font-size: 2rem;
                  color: var(--green);
                  font-weight: 700;
                "
              >
                3
              </div>
              <div
                style="
                  font-size: 0.75rem;
                  color: var(--text-muted);
                  font-weight: 600;
                "
              >
                Days
              </div>
            </div>
            <div
              style="
                background: #fff8e1;
                border-radius: 10px;
                padding: 16px;
                text-align: center;
              "
            >
              <div
                style="
                  font-family: var(--font-head);
                  font-size: 2rem;
                  color: #8a6700;
                  font-weight: 700;
                "
              >
                10+
              </div>
              <div
                style="
                  font-size: 0.75rem;
                  color: var(--text-muted);
                  font-weight: 600;
                "
              >
                Ministers
              </div>
            </div>
            <div
              style="
                background: #fdf0ee;
                border-radius: 10px;
                padding: 16px;
                text-align: center;
              "
            >
              <div
                style="
                  font-family: var(--font-head);
                  font-size: 2rem;
                  color: var(--red);
                  font-weight: 700;
                "
              >
                1k+
              </div>
              <div
                style="
                  font-size: 0.75rem;
                  color: var(--text-muted);
                  font-weight: 600;
                "
              >
                Attendees
              </div>
            </div>
            <div
              style="
                background: var(--green-pale);
                border-radius: 10px;
                padding: 16px;
                text-align: center;
              "
            >
              <div
                style="
                  font-family: var(--font-head);
                  font-size: 2rem;
                  color: var(--green);
                  font-weight: 700;
                "
              >
                Free
              </div>
              <div
                style="
                  font-size: 0.75rem;
                  color: var(--text-muted);
                  font-weight: 600;
                "
              >
                Registration
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- Special Programmes -->
  <section>
    <div class="container">
      <div class="section-header">
        <div class="section-label red">Special</div>
        <h2 class="section-title">Special Programmes</h2>
        <p class="section-subtitle">
          Special events that mark the year with encounters and milestones.
        </p>
      </div>
      <div class="prog-grid">
        <div class="prog-card red">
          <div class="prog-type">Yearly Events</div>
          <div class="prog-name">1st, 2nd &amp; 3rd of January, every year</div>
          <div class="prog-schedule">
            <span
              ><i
                class="fa fa-calendar"
                aria-hidden="true"
                style="margin-right: 6px"
              ></i>
              March 1 – March 9</span
            ><span
              ><i
                class="fa fa-map-marker-alt"
                aria-hidden="true"
                style="margin-right: 6px"
              ></i>
              Church Auditorium</span
            >
          </div>
          <div class="prog-desc">
            The entire church engages in days of consecration and edification of
            the body of Christ from ministers of the Word.
          </div>
        </div>
        <div class="prog-card yellow">
          <div class="prog-type">Annual Special</div>
          <div class="prog-name">Easter retreat &amp; Passion Play</div>
          <div class="prog-schedule">
            <span
              ><i
                class="fa fa-calendar"
                aria-hidden="true"
                style="margin-right: 6px"
              ></i>
              Good Friday</span
            ><span
              ><i
                class="fa fa-map-marker-alt"
                aria-hidden="true"
                style="margin-right: 6px"
              ></i>
              Main Sanctuary</span
            >
          </div>
          <div class="prog-desc">
            A dramatic presentation of the passion of Christ through music,
            drama, and dance — powerful, soul-stirring, and life-transforming
            every year.
          </div>
        </div>
        <div class="prog-card">
          <div class="prog-type">Annual Special</div>
          <div class="prog-name">Youth Camp</div>
          <div class="prog-schedule">
            <span
              ><i
                class="fa fa-calendar"
                aria-hidden="true"
                style="margin-right: 6px"
              ></i>
              June</span
            ><span
              ><i
                class="fa fa-map-marker-alt"
                aria-hidden="true"
                style="margin-right: 6px"
              ></i>
              Covenant Retreat Centre</span
            >
          </div>
          <div class="prog-desc">
            Three-day camp for ages 13–25. Leadership training, worship, sports,
            and discipleship activities that shape the next generation of
            leaders.
          </div>
        </div>
        <div class="prog-card red">
          <div class="prog-type">Annual Special</div>
          <div class="prog-name">Carol Service &amp; Thanksgiving</div>
          <div class="prog-schedule">
            <span
              ><i
                class="fa fa-calendar"
                aria-hidden="true"
                style="margin-right: 6px"
              ></i>
              December</span
            ><span
              ><i
                class="fa fa-map-marker-alt"
                aria-hidden="true"
                style="margin-right: 6px"
              ></i>
              Open Air Grounds</span
            >
          </div>
          <div class="prog-desc">
            A grand outdoor carol service and thanksgiving ceremony marking the
            end of the year — thanksgiving offerings, choir concert, and food
            sharing.
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
<%- include('../partials/footer') %> <%- include('../partials/scripts') %>
